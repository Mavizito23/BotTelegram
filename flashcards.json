[
  {
    "q": "Axiomas de Kolmogórov (1, 2 y 3)",
    "a": "1. P(A) ≥ 0. 2. P(Ω) = 1. 3. Aditividad numerable: P(∪Ai) = ΣP(Ai) para eventos ajenos."
  },
  {
    "q": "Regla de adición (n=2)",
    "a": "P(A ∪ B) = P(A) + P(B) - P(A ∩ B)"
  },
  {
    "q": "Leyes de De Morgan",
    "a": "(A ∪ B)^c = A^c ∩ B^c; (A ∩ B)^c = A^c ∪ B^c"
  },
  {
    "q": "Definición de probabilidad condicional P(A|B)",
    "a": "P(A|B) = P(A ∩ B) / P(B) con P(B) > 0"
  },
  {
    "q": "Condición de independencia",
    "a": "A y B son independientes si P(A ∩ B) = P(A)P(B)"
  },
  {
    "q": "Teorema de Bayes (forma general)",
    "a": "P(Bj|A) = [P(Bj)P(A|Bj)] / Σ[P(Bi)P(A|Bi)]"
  },
  {
    "q": "Varianza (fórmula fundamental)",
    "a": "Var(X) = E[X^2] - (E[X])^2"
  },
  {
    "q": "Linealidad de la esperanza",
    "a": "E[aX + b] = aE[X] + b"
  },
  {
    "q": "Desigualdad de Chebyshev",
    "a": "P(|X - μ| ≥ kσ) ≤ 1/k^2"
  },
  {
    "q": "Esperanza y Varianza de Binomial B(n,p)",
    "a": "E[X] = np; Var(X) = np(1-p)"
  },
  {
    "q": "Esperanza de la distribución Geométrica",
    "a": "E[X] = 1/p (ensayos hasta el primer éxito)"
  },
  {
    "q": "Esperanza y Varianza de Poisson",
    "a": "E[X] = λ; Var(X) = λ"
  },
  {
    "q": "Esperanza y Varianza de la Exponencial",
    "a": "E[X] = 1/λ; Var(X) = 1/λ^2"
  },
  {
    "q": "Propiedad de falta de memoria (Exponencial)",
    "a": "P(X > s+t | X > s) = P(X > t)"
  },
  {
    "q": "Estandarización de una Normal",
    "a": "Z = (X - μ) / σ ~ N(0,1)"
  },
  {
    "q": "Teorema Central del Límite (TCL)",
    "a": "La suma de n variables i.i.d. converge a una Normal(μ, σ^2/n) cuando n → ∞"
  }
]
