[
  {
    "q": "Axiomas de Kolmogórov (1, 2 y 3)",
    "a": "1. P(A) \\ge 0 \\quad 2. P(\\Omega) = 1 \\quad 3. \\displaystyle P\\left(\\bigcup_{i=1}^{\\infty} A_i\\right) = \\sum_{i=1}^{\\infty} P(A_i)"
  },
  {
    "q": "Regla de adición (n=2)",
    "a": "P(A \\cup B) = P(A) + P(B) - P(A \\cap B)"
  },
  {
    "q": "Leyes de De Morgan",
    "a": "(A \\cup B)^c = A^c \\cap B^c; \\quad (A \\cap B)^c = A^c \\cup B^c"
  },
  {
    "q": "Definición de probabilidad condicional P(A|B)",
    "a": "\\displaystyle P(A|B) = \\dfrac{P(A \\cap B)}{P(B)}, \\quad P(B) > 0"
  },
  {
    "q": "Condición de independencia",
    "a": "P(A \\cap B) = P(A) \\cdot P(B)"
  },
  {
    "q": "Teorema de Bayes (forma general)",
    "a": "\\displaystyle P(B_j|A) = \\dfrac{P(B_j)P(A|B_j)}{\\sum_{i=1}^{n} P(B_i)P(A|B_i)}"
  },
  {
    "q": "Varianza (fórmula fundamental)",
    "a": "\\text{Var}(X) = E[X^2] - (E[X])^2"
  },
  {
    "q": "Linealidad de la esperanza",
    "a": "E[aX + b] = aE[X] + b"
  },
  {
    "q": "Desigualdad de Chebyshev",
    "a": "\\displaystyle P(|X - \\mu| \\ge k\\sigma) \\le \\dfrac{1}{k^2}"
  },
  {
    "q": "Esperanza y Varianza de Binomial B(n,p)",
    "a": "E[X] = np, \\quad \\text{Var}(X) = np(1-p)"
  },
  {
    "q": "Esperanza de la distribución Geométrica",
    "a": "E[X] = \\dfrac{1}{p}"
  },
  {
    "q": "Esperanza y Varianza de Poisson",
    "a": "E[X] = \\lambda, \\quad \\text{Var}(X) = \\lambda"
  },
  {
    "q": "Esperanza y Varianza de la Exponencial",
    "a": "\\displaystyle E[X] = \\dfrac{1}{\\lambda}, \\quad \\text{Var}(X) = \\dfrac{1}{\\lambda^2}"
  },
  {
    "q": "Propiedad de falta de memoria (Exponencial)",
    "a": "P(X > s+t \\mid X > s) = P(X > t)"
  },
  {
    "q": "Estandarización de una Normal",
    "a": "\\displaystyle Z = \\dfrac{X - \\mu}{\\sigma} \\sim N(0,1)"
  },
  {
    "q": "Teorema Central del Límite (TCL)",
    "a": "\\displaystyle \\dfrac{\\bar{X}_n - \\mu}{\\sigma/\\sqrt{n}} \\xrightarrow{d} N(0,1)"
  },
  {
    "q": "PMF Binomial B(n,p)",
    "a": "\\displaystyle P(X=k) = \\binom{n}{k} p^k (1-p)^{n-k}"
  },
  {
    "q": "PMF Poisson P(λ)",
    "a": "\\displaystyle P(X=k) = \\dfrac{e^{-\\lambda} \\lambda^k}{k!}"
  },
  {
    "q": "PMF Geométrica G(p)",
    "a": "P(X=k) = (1-p)^{k-1} p"
  },
  {
    "q": "PDF Uniforme Continua U(a,b)",
    "a": "\\displaystyle f(x) = \\dfrac{1}{b-a}, \\quad a < x < b"
  },
  {
    "q": "Esperanza y Varianza Uniforme",
    "a": "\\displaystyle E[X] = \\dfrac{a+b}{2}, \\quad \\text{Var}(X) = \\dfrac{(b-a)^2}{12}"
  },
  {
    "q": "PDF Exponencial Exp(λ)",
    "a": "f(x) = \\lambda e^{-\\lambda x}, \\quad x > 0"
  },
  {
    "q": "PDF Normal N(μ, σ²)",
    "a": "\\displaystyle f(x) = \\dfrac{1}{\\sqrt{2\\pi\\sigma^2}} e^{-\\frac{(x-\\mu)^2}{2\\sigma^2}}"
  },
  {
    "q": "PMF Hipergeométrica",
    "a": "\\displaystyle P(X=k) = \\dfrac{\\binom{M}{k} \\binom{N-M}{n-k}}{\\binom{N}{n}}"
  }
]
